# ===============================
# JWT
# ===============================
# JWT_SECRET=최소 32자 이상의 랜덤 문자열 (예: openssl rand -base64 32)
# JWT_EXPIRY_SECONDS=7200

# ===============================
# Database (TiDB Cloud - MySQL 호환)
# ===============================
# TIDB_URL=jdbc:mysql://<host>:<port>/<database>?sslMode=VERIFY_IDENTITY
# TIDB_USERNAME=
# TIDB_PASSWORD=

# ===============================
# External API
# ===============================
# NAVER_CLIENT_ID=
# NAVER_CLIENT_SECRET=

# ===============================
# AWS (EC2 배포 시)
# ===============================
# AWS_REGION=ap-northeast-2
# AWS_S3_BUCKET=

# ===============================
# Feature Flags (기본 OFF)
# ===============================
# AUTO_ORDER_ENABLED=0
# RPA_SCHEDULER_ENABLED=0

# ===============================
# App Config
# ===============================
# SERVER_PORT=8080
# LOG_LEVEL=INFO
# SPRING_PROFILES_ACTIVE=dev
# CORS_ALLOWED_ORIGINS=http://localhost:3000  # 배포 시 실제 도메인으로 변경 (쉼표로 복수 설정 가능)
