# ===============================
# JWT
# ===============================
# JWT_SECRET=at-least-32-bytes-random-string
# JWT_EXPIRY_SECONDS=7200

# ===============================
# Database (TiDB Cloud / MySQL compatible)
# ===============================
# TIDB_URL=jdbc:mysql://<host>:<port>/<database>?sslMode=VERIFY_IDENTITY
# TIDB_USERNAME=
# TIDB_PASSWORD=

# ===============================
# External API
# ===============================
# NAVER_CLIENT_ID=
# NAVER_CLIENT_SECRET=

# ===============================
# AWS / Deployment
# ===============================
# AWS_REGION=ap-northeast-2
# AWS_S3_BUCKET=

# ===============================
# Feature Flags (default OFF)
# ===============================
# AUTO_ORDER_ENABLED=0
# RPA_SCHEDULER_ENABLED=0

# ===============================
# App Config
# ===============================
# SERVER_PORT=8080
# LOG_LEVEL=INFO
# SPRING_PROFILES_ACTIVE=dev

# Local browser dev defaults are already provided in application.yml.
# Production must override this with the real EC2 IP or domain origins.
# CORS_ALLOWED_ORIGINS=http://your-ec2-ip,https://your-domain.com

# 자주쓰게 될 명령어 정리
# ./gradlew clean
# ./gradlew bootRun
# ctrl + shift + p -> java.clean.workspace
# 
# 
# 점유중인 port, pid 죽이는 명령어 (윈도우)
# netstat -ano | findstr :8080
# taskkill /f /pid [찾은PID]

# 점유중인 port, pid 죽이는 명령어 (Linux)
# lsof -i :8080
# netstat -tlpn | grep :8080
# kill -9 [찾은PID]

# 점유중인 port, pid 죽이는 명령어 (MaxOs)
# lsof -i :8080
# netstat -tlpn | grep :8080
# kill -9 [찾은PID]

# 크롤링중에 백그라운드에서 좀비가된 크롬드라이버 프로세스 강제 종료 
# taskkill /f /im chromedriver.exe /t  # 모든 크롬드라이버 프로세스 강제 종료 (윈도우)
# taskkill /f /im chrome.exe /t # 모든 크롬 프로세스 강제 종료 (윈도우)

# Linux
# pkill -9 chromedriver
# Chromium을 사용하는 경우
# pkill -9 chromium
# # 일반 Google Chrome인 경우
# pkill -9 chrome
# PID를 못 찾을 때의 대안 (killall):
# killall -9 chromedriver

# macOs 드라이버 일때
# pkill -9 chromedriver
# macOs 브라우저 일때
# pkill -9 "Google Chrome"